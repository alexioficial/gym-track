# --- Base de datos ---
# Conexión a MongoDB (local, docker-compose o Atlas)
MONGODB_URI=mongodb://localhost:27017
# Nombre de la base de datos
MONGODB_DB=gym_tracker

# --- Autenticación ---
# PIN/contraseña única para entrar a la app
AUTH_PIN=1234
# Secreto para firmar la cookie de sesión (usa algo largo y aleatorio en prod)
# genera uno con: openssl rand -hex 32
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- Servidor (adapter-node) ---
# Origen público de la app. NECESARIO en producción para que funcionen los form actions (CSRF).
# En Coolify ponlo con la URL final, ej: https://gym.midominio.com
ORIGIN=http://localhost:3000
# Puerto (Coolify normalmente lo inyecta). adapter-node usa 3000 por defecto.
PORT=3000
