# --- Database ---
MONGODB_URI=
MONGODB_DB=gym_tracker

# --- Auth ---
# Secret used to sign the session cookie. Generate one, e.g.: openssl rand -hex 32
SESSION_SECRET=

# Public origin of the app (adapter-node needs it in prod for form actions / CSRF).
ORIGIN=https://

# Admin account seeded on first start (create other users from inside the app).
# Optional — defaults to alexioficial / 1029384756 if omitted.
ADMIN_USERNAME=alexioficial
ADMIN_PASSWORD=1029384756

# --- Server ---
PORT=3000
