# --- Database ---
MONGODB_URI=
MONGODB_DB=gym_tracker

# --- Auth ---
# Secret used to sign the session cookie. Generate one, e.g.: openssl rand -hex 32
SESSION_SECRET=

# Public origin of the app (adapter-node needs it in prod for form actions / CSRF).
ORIGIN=https://

# Admin account (create other users from inside the app).
# ADMIN_USERNAME: optional, defaults to alexioficial.
# ADMIN_PASSWORD: authoritative — the admin's password is synced to this value on
#   every start, so set a STRONG one here and redeploy to rotate it. If omitted, a
#   brand-new admin is bootstrapped with a weak default; set this in production.
ADMIN_USERNAME=alexioficial
ADMIN_PASSWORD=

# --- Server ---
PORT=3000
